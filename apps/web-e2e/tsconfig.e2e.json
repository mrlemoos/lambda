{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "outDir": "out-tsc/playwright",
    "sourceMap": false,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["dom"],
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "playwright.config.mts"],
  "exclude": ["out-tsc", "test-output"]
}
