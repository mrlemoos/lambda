{
  "name": "@lambda/desktop",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/desktop/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "generate-icons": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/desktop",
        "command": "python3 scripts/generate-icons.py"
      },
      "outputs": [
        "{projectRoot}/public/favicon.ico",
        "{projectRoot}/public/icons",
        "{projectRoot}/src/assets/icons"
      ]
    },
    "dev": {
      "continuous": true,
      "executor": "nx:run-commands",
      "dependsOn": ["^build", "generate-icons"],
      "options": {
        "cwd": "apps/desktop",
        "command": "rm -rf node_modules/.vite && env -u ELECTRON_RUN_AS_NODE electron-vite dev"
      }
    },
    "verify-editor-bundle": {
      "executor": "nx:run-commands",
      "dependsOn": ["@lambda/editor:build"],
      "options": {
        "cwd": "apps/desktop",
        "command": "node scripts/verify-editor-bundle.mjs"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build", "generate-icons"],
      "options": {
        "cwd": "apps/desktop",
        "command": "electron-vite build"
      },
      "outputs": ["{projectRoot}/out"]
    }
  }
}
